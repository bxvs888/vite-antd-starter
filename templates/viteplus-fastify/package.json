{
  "name": "viteplus-fastify",
  "version": "1.0.0",
  "description": "Modern VitePlus Fastify template with TypeScript and latest conventions",
  "keywords": [
    "fastify",
    "modern",
    "nodejs",
    "rest-api",
    "starter",
    "typescript"
  ],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/server.mjs",
  "scripts": {
    "dev": "cross-env NODE_ENV=development APP_ENV=development vp pack --watch --on-success \"vp run start:dev\"",
    "start:dev": "cross-env NODE_ENV=development APP_ENV=development node ./dist/server.mjs",
    "start": "cross-env NODE_ENV=production node ./dist/server.mjs",
    "start:prod": "cross-env NODE_ENV=production node ./dist/server.mjs",
    "build": "cross-env NODE_ENV=production vp run build:server && vp run build:client",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "vp pack",
    "build:dev": "vp pack",
    "compile-schemas": "json2ts -i src/schemas -o src/types",
    "check": "vp check",
    "type-check": "tsc --noEmit",
    "lint": "vp lint --fix",
    "format": "vp fmt",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "prepare": "vp config"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/vite": "^9.0.2",
    "dayjs": "^1.11.20",
    "fastify": "^5.8.5",
    "ioredis": "^5.10.1",
    "knex": "^3.2.10",
    "lodash": "^4.18.1",
    "mysql": "^2.18.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.2",
    "cross-env": "^10.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vite-plus": "0.1.24"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
